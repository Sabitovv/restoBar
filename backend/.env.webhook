# Core app
DEV_MODE=1
DEV_APP_URL=http://localhost:3000
ADMIN_DEV_APP_URL=http://localhost:5173
APP_URL=https://miniapp.restobar.su
ADMIN_APP_URL=https://admin.restobar.su
WEBHOOK_URL=https://miniapp.restobar.su
BOT_MODE=webhook
ADMIN_SESSION_SECRET=change-me

# Telegram
BOT_TOKEN=replace_with_bot_token
PAYMENT_PROVIDER_TOKEN=replace_with_payment_provider_token

# Persistence
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/tma_cafe
REDIS_URL=redis://localhost:6379/0

# AI
ENABLE_AI_BOT_REPLIES=1
GEMINI_API_KEY=replace_with_gemini_api_key
AI_MODEL=gemini-2.5-flash
AI_REQUEST_TIMEOUT_SECONDS=10
AI_MAX_RETRIES=2
AI_WEB_SEARCH_ENABLED=1
TAVILY_API_KEY=replace_with_tavily_api_key
TAVILY_TIMEOUT_SECONDS=7
TAVILY_MAX_RESULTS=3
RQ_QUEUE_NAME=ai

# Menu cutover
READ_MENU_FROM_PG=1
JSON_MENU_FALLBACK=1

# Migration flags
DUAL_WRITE_ORDERS=1
WRITE_ORDERS_TO_JSON=1
ORDERS_JSON_PATH=data/orders.json

# Observability
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
